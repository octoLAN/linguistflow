# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://linguist:password@localhost:5432/linguistflow

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai         # openai | anthropic

# ── Image APIs ───────────────────────────────────────────
PEXELS_API_KEY=...
STABLE_DIFFUSION_API_KEY=...
STABLE_DIFFUSION_ENDPOINT=https://api.stability.ai/v1/generation/stable-diffusion-xl-1024-v1-0/text-to-image

# ── Security ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-64-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ──────────────────────────────────────────────────
APP_NAME=LinguistFlow
FRONTEND_ORIGIN=http://localhost:5173
DEBUG=true

# ── Compliance ───────────────────────────────────────────
LOG_CLIENT_IPS=false          # MUST remain false for GDPR compliance
