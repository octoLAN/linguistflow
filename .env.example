# ── Database ──────────────────────────────────────────────
POSTGRES_USER=linguist
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=linguistflow
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_LLM_PROVIDER=gemini         # openai | anthropic | gemini

# ── Research / Academic APIs ──────────────────────────────
OPENALEX_API_KEY=your_openalex_api_key_here

# ── Image APIs ────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here
STABLE_DIFFUSION_API_KEY=your_stable_diffusion_api_key_here
STABLE_DIFFUSION_ENDPOINT=https://api.stability.ai/v1/generation/stable-diffusion-xl-1024-v1-0/text-to-image

# ── Security ──────────────────────────────────────────────
SECRET_KEY=generate_a_secure_64_character_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────
APP_NAME=LinguistFlow
FRONTEND_ORIGIN=http://localhost:5173
DEBUG=true

# ── Compliance ────────────────────────────────────────────
LOG_CLIENT_IPS=false          # MUST remain false for GDPR compliance

# ── Search API ────────────────────────────────────────────
SERP_API_KEY=your_serp_api_key_here
